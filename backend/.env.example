# =============================================================================
# Invoice Expense Manager — Backend Environment Variables
# =============================================================================
# Copia este archivo como .env y completa los valores según tu entorno.
# NUNCA subas el archivo .env al repositorio.

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# URL del proyecto Supabase (obtenida desde Project Settings > API)
SUPABASE_URL=

# Clave anónima de Supabase (obtenida desde Project Settings > API)
SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Orígenes permitidos para CORS (separados por coma)
# Ejemplo producción: https://mi-app.vercel.app
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# VLM Service (Moondream2)
# -----------------------------------------------------------------------------

# Modo de conexión al servidor Moondream2: "local" (Ollama) o "remote" (API externa)
VLM_MODE=local

# URL del servidor Ollama local (solo aplica cuando VLM_MODE=local)
VLM_LOCAL_URL=http://localhost:11434

# Modelo local a usar con Ollama (solo aplica cuando VLM_MODE=local)
VLM_LOCAL_MODEL=llava

# URL de la API remota de Moondream2 (solo aplica cuando VLM_MODE=remote)
VLM_REMOTE_URL=

# Timeout en milisegundos para cada solicitud al VLM (default: 120000 = 2 minutos)
VLM_TIMEOUT_MS=120000

# -----------------------------------------------------------------------------
# Telegram Bot
# -----------------------------------------------------------------------------

# Token del bot de Telegram (obtenido desde @BotFather)
TELEGRAM_BOT_TOKEN=

# URL pública del servidor para recibir webhooks de Telegram
# Ejemplo: https://mi-servidor.com/api/telegram/webhook
TELEGRAM_WEBHOOK_URL=

# IDs de usuarios de Telegram autorizados para usar el bot (separados por coma)
# Ejemplo: 123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=

# -----------------------------------------------------------------------------
# Servidor Express
# -----------------------------------------------------------------------------

# Puerto en el que escucha el servidor (default: 3001)
PORT=3001

# Entorno de ejecución: development | production | test
NODE_ENV=development
